# axension-agent1 / .env.example
# ───────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in your values.  NEVER commit .env.
#
#     cp .env.example .env
#
# Twilio has been removed. All WhatsApp goes through Meta WABA.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Supabase / PostgreSQL ──────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string → URI
DB_URL= postgresql://postgres.zwgoujseohygllrsmokk:Axension2026db@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# ─── Redis (Celery broker + rate limiter) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Meta WhatsApp Cloud API ────────────────────────────────────────────────
# Get these from: https://developers.facebook.com
#   → Your App → WhatsApp → API Setup
#
# WABA_TOKEN     : Temporary or permanent access token
# WABA_PHONE_ID  : Phone number ID (NOT the phone number itself)
# WABA_VERSION   : Meta Graph API version (v19.0 is stable)
# WABA_VERIFY_TOKEN : Any random string you choose — must match
#                     what you enter in Meta webhook settings
WABA_TOKEN=EAAXlanvpc6oBRAHtrd5M2fflZAhzGN4oPcWavM9cER2pm4EX4GkEmcxe6ZC47fZA5JPgJq5zd4puVPOx4TnShb0PHWrj87y8BR5qNwi0rLaSPwzsWEqZBiwVWZA9eqQKou3JxtZBEwJtpuYULJpGTot0ZCsoG2LGNJWFvvfoLGlgyjUpTovxDGhjsWZCQuHunY4gGTvcaUDJaZAf1geV9i2ZCYTturQIj1ye7ZCFLzzEooSt6q5PY0BhjCrZAZBq3uSC2DHJZAd7VaYbOmkHQrIW4ZAgbzpdNcg
WABA_PHONE_ID=1075135535682247
WABA_VERSION=v19.0
WABA_VERIFY_TOKEN=axension_verify

# ─── Phone Numbers ──────────────────────────────────────────────────────────
# Factory owner's WhatsApp number — E.164 without '+', no spaces
# Example (India): 918121444200
OWNER_PHONE=918121444200

# ─── Agent 1 Config ─────────────────────────────────────────────────────────
FACTORY_ID=factory_001
MAX_MESSAGES_PER_RUN=3

# ─── Safety Rail ────────────────────────────────────────────────────────────
# true  → fake wamid returned, NO real WhatsApp sent (safe for testing)
# false → real Meta WABA calls go out (use for production / Day 6+)
DRY_RUN=false

# ─── Dev Override (optional) ────────────────────────────────────────────────
# Uncomment to run Celery beat every N minutes instead of 8 AM IST
# AGENT1_INTERVAL_MINUTES=1

# Webhook port
WEBHOOK_PORT=5000

# ═══════════════════════════════════════════════════════════════════════════
# HOW TO GET YOUR META WABA CREDENTIALS
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. Go to https://developers.facebook.com
# 2. Create or open your App
# 3. Add "WhatsApp" product to the app
# 4. Go to WhatsApp → API Setup
# 5. You'll see:
#    - "Temporary access token" → paste as WABA_TOKEN
#    - "Phone number ID" → paste as WABA_PHONE_ID
# 6. To send to your own number for testing:
#    - Scroll to "Send and receive messages"
#    - Enter your phone number and click "Send message"
#    - You'll receive a test message
#
# HOW TO SET UP THE WEBHOOK
# ─────────────────────────
# 1. Expose localhost:5000 to the internet:
#    Cloudflare: cloudflared tunnel --url http://localhost:5000
#    ngrok:      ngrok http 5000
# 2. Copy the public URL (e.g. https://xxx.ngrok-free.app)
# 3. Go to Meta Developer Console:
#    App → WhatsApp → Configuration → Webhook
#    Callback URL: https://YOUR-URL/webhook
#    Verify Token: axension_verify  (matches WABA_VERIFY_TOKEN above)
# 4. Click "Verify and Save"
# 5. Subscribe to the "messages" field
# ═══════════════════════════════════════════════════════════════════════════
